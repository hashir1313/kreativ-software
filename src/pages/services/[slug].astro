---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import Section from "../../components/sections/Section.astro";
import Card from "../../components/ui/Card.astro";
import Contact from "../../components/sections/Contact.astro";
import "../../styles/globals.css";

import services from "../../data/services.json";
import gob from "../../assets/icon6.svg";
import proposalImg from "../../assets/pics/proposal-pic.png";

const imageModules = import.meta.glob<{ default: any }>(
  "../../assets/pics/card-*.png",
  { eager: true },
);

function resolveImage(path: string) {
  const key = Object.keys(imageModules).find((k) =>
    k.endsWith(path.split("/").pop()!),
  );
  return key ? imageModules[key].default : null;
}

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const otherServices = services.filter((s) => s.slug !== service.slug);
const img = resolveImage(service.image);
---

<MainLayout
  title={`${service.title} | Hifza`}
  description={service.description}
>
  <!-- Hero -->
  <Section id="home">
    <div class="grid grid-cols-1 md:grid-cols-2 mt-[12rem] gap-10 items-center">
      <div class="flex flex-col">
        <a
          href="/"
          class="flex items-center gap-2 text-sm mb-6 hover:text-green transition-colors"
        >
          <span>&larr;</span>
          <span>Back to Home</span>
        </a>
        <span class="greenhead w-fit mb-6">0{service.index}</span>
        <h1>{service.title}</h1>
        <p class="my-[35px]">{service.heroText}</p>
        <a class="btn-primary w-full md:w-fit" href="#contact">Get started</a>
      </div>
      <div class="flex justify-center items-center">
        <Image src={img} alt={service.title} />
      </div>
    </div>
  </Section>

  <!-- What You Get -->
  <Section>
    <div class="mt-[140px]">
      <div class="flex flex-col justify-center gap-5 mb-20 items-center text-center md:items-start md:text-start">
        <h2 class="greenhead w-fit">What You Get</h2>
        <p class="max-w-[600px]">{service.description}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 pb-1.5">
        {
          service.features.map((feature) => (
            <Card isUnderline={true} >
              <div class="p-[30px] h-full bg-[#F3F3F3] rounded-[45px] flex items-center justify-center">
                <span class="text-center font-medium">{feature}</span>
              </div>
            </Card>
          ))
        }
      </div>
    </div>
  </Section>

  <!-- How We Do It -->
  <Section>
    <div class="mt-[140px]">
      <div class="flex flex-col gap-5 mb-20 items-center text-center md:items-start md:text-start">
        <h2 class="greenhead w-fit">How We Do It</h2>
        <p class="max-w-[600px]">
          Our structured approach ensures consistent, measurable results for
          every client.
        </p>
      </div>
      <div class="flex flex-col gap-[30px] pb-1.5">
        {
          service.details.map((detail, i) => (
            <div class="flex items-center gap-6 p-[40px] rounded-[45px] border border-dark shadow-[0px_5px_0px_#191a23] bg-white">
              <span class="text-4xl font-bold text-black shrink-0">
                0{i + 1}
              </span>
              <p class="">{detail}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section>
    <Card>
      <div
        class="flex bg-[#F3F3F3] rounded-[45px] p-[60px] relative mb-[10rem] mt-[6rem]"
      >
        <div class="w-full md:w-[40%] flex flex-col gap-[26px] items-center text-center md:items-start md:text-start">
          <h2>Ready to get started?</h2>
          <p>
            Let's discuss how our {service.title.toLowerCase()} services can help
            your business grow.
          </p>
          <a class="btn-primary" href="#contact">Book a consultation</a>
        </div>
        <picture
          class="hidden md:flex absolute right-[-10%] lg:right-0 top-[-15%] h-[450px] items-center justify-center"
        >
          <Image
            src={proposalImg}
            alt="Let's make things happen"
            class="hidden md:flex lg:h-full lg:w-auto"
          />
        </picture>
      </div>
    </Card>
  </Section>

  <!-- Other Services -->
   {otherServices.length > 0 && (
  <Section>
    <div class="mb-[40px]">
      <div class="flex flex-col gap-5 mb-10 items-center text-center md:items-start md:text-start">
        <h2 class="greenhead w-fit">Other Services</h2>
        <p>Explore what else we can do for you.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          otherServices.map((s) => (
            <a href={`/services/${s.slug}`} class="block">
              <Card isUnderline={true}>
                <div class="p-[40px] h-full bg-dark text-white rounded-[45px] flex flex-col justify-between min-h-[200px]">
                  <span class="text-green text-3xl font-bold">0{s.index}</span>
                  <h3 class="mt-4">{s.title}</h3>
                  <div class="flex items-center gap-3 mt-6">
                    <span class="text-green">Learn more</span>
                    <Image src={gob} alt="Arrow" />
                  </div>
                </div>
              </Card>
            </a>
          ))
        }
      </div>
    </div>
  </Section>
   )}

  <!-- Contact -->
  <Contact />
</MainLayout>
